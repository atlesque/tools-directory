---
import { tools } from '../data/tools';
import '../styles/global.css';

const categories = [...new Set(tools.map((tool) => tool.category))].sort();
const deployedCount = tools.filter((tool) => tool.websiteUrl).length;

const themeIcons: Record<string, string> = { light: '☀', dark: '☾', auto: '◐' };
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="A directory of public tool repositories by atlesque." />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>Tools Directory</title>
    <script is:inline>
      (() => {
        const t = localStorage.getItem('theme');
        if (t === 'light' || t === 'dark') document.documentElement.setAttribute('data-theme', t);
      })();
    </script>
  </head>
  <body>
    <header class="site-header">
      <nav class="navbar" aria-label="Main navigation">
        <a href="/" class="site-title">Tools Directory</a>
        <button
          class="theme-toggle"
          type="button"
          aria-label="Toggle color scheme"
          title="Toggle color scheme"
        >
          {themeIcons['auto']}
        </button>
      </nav>
    </header>

    <main class="page-shell">
      <section class="intro" aria-labelledby="page-title">
        <div>
          <p class="eyebrow">atlesque public tools</p>
          <h1 id="page-title" class="sr-only">Tools Directory</h1>
          <p class="lede">
            A one-page index of small utilities, helpers, solvers, converters, and workflow tools.
          </p>
        </div>
        <dl class="stats" aria-label="Directory summary">
          <div>
            <dt>{tools.length}</dt>
            <dd>tools</dd>
          </div>
          <div>
            <dt>{deployedCount}</dt>
            <dd>verified sites</dd>
          </div>
          <div>
            <dt>{categories.length}</dt>
            <dd>categories</dd>
          </div>
        </dl>
      </section>

      <div class="search-bar">
        <label for="tool-search" class="sr-only">Search tools</label>
        <input
          id="tool-search"
          type="search"
          placeholder="Search tools by name, description, or category…"
          autocomplete="off"
        />
        <span class="search-status" id="search-status" aria-live="polite"></span>
      </div>

      <nav class="category-nav" aria-label="Tool categories">
        {categories.map((category) => (
          <a href={`#${category.toLowerCase()}`}>{category}</a>
        ))}
      </nav>

      <section class="tool-grid" aria-label="Tools">
        {categories.map((category) => (
          <div class="category-group" id={category.toLowerCase()}>
            <h2>{category}</h2>
            <div class="cards">
              {tools
                .filter((tool) => tool.category === category)
                .map((tool) => (
                  <article
                    class="tool-card"
                    data-search-text={`${tool.name} ${tool.description} ${tool.category}`}
                  >
                    <div>
                      <h3>{tool.name}</h3>
                      <p>{tool.description}</p>
                    </div>
                    <div class="links">
                      {tool.websiteUrl && (
                        <a class="primary-link" href={tool.websiteUrl}>Website</a>
                      )}
                      <a href={tool.githubUrl}>GitHub</a>
                    </div>
                  </article>
                ))}
            </div>
          </div>
        ))}
      </section>
    </main>

    <script>
      const searchInput = document.getElementById('tool-search') as HTMLInputElement;
      const statusEl = document.getElementById('search-status') as HTMLSpanElement;

      searchInput.focus();

      searchInput.addEventListener('input', () => {
        const query = searchInput.value.trim().toLowerCase();
        const cards = document.querySelectorAll<HTMLElement>('.tool-card');
        const groups = document.querySelectorAll<HTMLElement>('.category-group');
        let visibleCount = 0;

        cards.forEach((card) => {
          const text = (card.dataset.searchText ?? '').toLowerCase();
          const match = !query || text.includes(query);
          card.classList.toggle('hidden', !match);
          if (match) visibleCount++;
        });

        groups.forEach((group) => {
          const visibleCards = group.querySelectorAll('.tool-card:not(.hidden)');
          group.classList.toggle('hidden', visibleCards.length === 0);
        });

        if (query) {
          statusEl.textContent = `${visibleCount} tool${visibleCount !== 1 ? 's' : ''} found`;
        } else {
          statusEl.textContent = '';
        }
      });
    </script>

    <script>
      const STORAGE_KEY = 'theme';
      const order: string[] = ['light', 'dark', 'auto'];
      const icons: Record<string, string> = { light: '☀', dark: '☾', auto: '◐' };
      const toggle = document.querySelector<HTMLButtonElement>('.theme-toggle')!;

      function applyTheme(theme: string) {
        if (theme === 'auto') {
          document.documentElement.removeAttribute('data-theme');
          localStorage.removeItem(STORAGE_KEY);
        } else {
          document.documentElement.setAttribute('data-theme', theme);
          localStorage.setItem(STORAGE_KEY, theme);
        }
        toggle.textContent = icons[theme];
      }

      const stored = localStorage.getItem(STORAGE_KEY);
      const current = stored === 'light' || stored === 'dark' ? stored : 'auto';
      applyTheme(current);

      toggle.addEventListener('click', () => {
        const cur = localStorage.getItem(STORAGE_KEY) || 'auto';
        const idx = (order.indexOf(cur) + 1) % order.length;
        applyTheme(order[idx]);
      });
    </script>
  </body>
</html>
